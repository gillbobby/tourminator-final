<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="indoor_mapping_robot">
  
  <!-- =====================================================
       ROBOT PHYSICAL PARAMETERS - VERIFIED FROM HARDWARE
       Based on actual measurements and test results
       ===================================================== -->
  
  <!-- Base chassis dimensions -->
  <xacro:property name="base_width" value="0.28575"/>      <!-- 50cm wide -->
  <xacro:property name="base_length" value="0.3175"/>      <!-- 40cm long -->
  <xacro:property name="base_height" value="0.5969"/>      <!-- 30cm high -->
  <xacro:property name="base_mass" value="9.0"/>           <!-- ~15kg total -->
  
  <!-- Wheel specifications (VERIFIED: POLOLU 144x29mm) -->
  <xacro:property name="wheel_radius" value="0.072"/>   <!-- 72mm radius -->
  <xacro:property name="wheel_width" value="0.029"/>    <!-- 29mm wide -->
  <xacro:property name="wheel_mass" value="0.5"/>       <!-- ~500g per wheel -->
  
  <!-- Wheelbase (VERIFIED from motor tests: 1.5 feet = 0.2413m) -->
  <xacro:property name="wheelbase" value="0.2413"/>
  <xacro:property name="wheel_offset_z" value="-0.05"/> <!-- Wheels below base -->
  
  <!-- Camera pole (4 feet tall) -->
  <xacro:property name="pole_height" value="1.219"/>    <!-- 4 feet = 1.219m -->
  <xacro:property name="pole_radius" value="0.02"/>     <!-- 2cm radius -->
  
  <!-- Sensor mounting positions (VERIFIED) -->
  <xacro:property name="lidar_x_offset" value="0.11"/>  <!-- 11cm forward -->
  <xacro:property name="lidar_y_offset" value="0.0"/>   <!-- Centered -->
  <xacro:property name="lidar_z_offset" value="0.0"/>   <!-- At base level -->
  
  <!-- IMU mounting position (near Raspberry Pi) -->
  <xacro:property name="imu_x_offset" value="0.0"/>     <!-- Robot center -->
  <xacro:property name="imu_y_offset" value="-0.10"/>   <!-- 10cm right of center (near Pi) -->
  <xacro:property name="imu_z_offset" value="0.05"/>    <!-- 5cm above base -->
  
  <!-- =====================================================
       VISUAL MATERIALS
       ===================================================== -->
  
  <material name="wood_brown">
    <color rgba="0.6 0.4 0.2 1.0"/>
  </material>
  
  <material name="metal_gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  
  <material name="black_rubber">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  
  <material name="blue_electronics">
    <color rgba="0.0 0.2 0.8 1.0"/>
  </material>
  
  <material name="red_lidar">
    <color rgba="1.0 0.0 0.0 1.0"/>
  </material>
  
  <material name="green_imu">
    <color rgba="0.0 0.8 0.2 1.0"/>
  </material>
  
  <!-- =====================================================
       BASE LINK (Robot Main Body)
       ===================================================== -->
  
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="wood_brown"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length + 0.02} ${base_width + 0.02} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="${base_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="${base_mass/12 * (base_width*base_width + base_height*base_height)}" 
               ixy="0" ixz="0"
               iyy="${base_mass/12 * (base_length*base_length + base_height*base_height)}" 
               iyz="0"
               izz="${base_mass/12 * (base_length*base_length + base_width*base_width)}"/>
    </inertial>
  </link>
  
  <!-- =====================================================
       WHEELS (Left + Right Drive Wheels + Rear Caster)
       Motor configuration: GPIO pins 17,18 (left) and 22,23 (right)
       CORRECTED: Differential drive configuration
       ===================================================== -->

  <!-- Left Drive Wheel (Motor pins 17,18) -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black_rubber"/>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="${wheel_mass/12 * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}" 
               ixy="0" ixz="0"
               iyy="${wheel_mass/12 * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}" 
               iyz="0"
               izz="${wheel_mass/2 * wheel_radius*wheel_radius}"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- Position: center of robot, left side -->
    <origin xyz="0 ${wheelbase/2} ${wheel_offset_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right Drive Wheel (Motor pins 22,23) -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black_rubber"/>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="${wheel_mass/12 * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}" 
               ixy="0" ixz="0"
               iyy="${wheel_mass/12 * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}" 
               iyz="0"
               izz="${wheel_mass/2 * wheel_radius*wheel_radius}"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- Position: center of robot, right side -->
    <origin xyz="0 ${-wheelbase/2} ${wheel_offset_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rear Caster Wheel (Passive Support) -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <!-- Smaller caster wheel -->
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="metal_gray"/>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="caster_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <!-- Position: rear center of robot -->
    <origin xyz="${-base_length/2 + 0.05} 0 ${wheel_offset_z - 0.02}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <!-- =====================================================
       CAMERA POLE (4-foot painter's pole)
       ===================================================== -->
  
  <link name="camera_pole">
    <visual>
      <geometry>
        <cylinder radius="${pole_radius}" length="${pole_height}"/>
      </geometry>
      <material name="metal_gray"/>
      <origin xyz="0 0 ${pole_height/2}" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${pole_radius}" length="${pole_height}"/>
      </geometry>
      <origin xyz="0 0 ${pole_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 ${pole_height/2}" rpy="0 0 0"/>
      <inertia ixx="${2.0/12 * (3*pole_radius*pole_radius + pole_height*pole_height)}" 
               ixy="0" ixz="0"
               iyy="${2.0/12 * (3*pole_radius*pole_radius + pole_height*pole_height)}" 
               iyz="0"
               izz="${2.0/2 * pole_radius*pole_radius}"/>
    </inertial>
  </link>
  
  <joint name="base_to_pole" type="fixed">
    <parent link="base_link"/>
    <child link="camera_pole"/>
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
  </joint>
  
  <!-- =====================================================
       LIDAR SENSOR (RPLidar A1M8) - VERIFIED POSITION
       ===================================================== -->
  
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.06"/>
      </geometry>
      <material name="red_lidar"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.06"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <joint name="base_to_lidar" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="${lidar_x_offset} ${lidar_y_offset} ${lidar_z_offset}" rpy="0 0 0"/>
  </joint>
  
  <!-- Additional laser frame for compatibility -->
  <link name="laser">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="lidar_to_laser" type="fixed">
    <parent link="lidar_link"/>
    <child link="laser"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  
  <!-- =====================================================
       IMU SENSOR (GY-91 / MPU6500)
       Mounted near Raspberry Pi, away from EMI sources
       
       VERIFIED ORIENTATION from physical testing:
       - IMU Y-axis → Robot FORWARD (X)
       - IMU X-axis → Robot LEFT (Y)
       - IMU Z-axis → Robot UP (Z)
       ===================================================== -->
  
  <link name="imu_link">
    <visual>
      <geometry>
        <!-- GY-91 board dimensions: approximately 20x15x3mm -->
        <box size="0.020 0.015 0.003"/>
      </geometry>
      <material name="green_imu"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.020 0.015 0.003"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.01"/>  <!-- ~10g for IMU board -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  
  <joint name="base_to_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- 
    Position: Near Raspberry Pi (right side of robot center, 5cm above base)
    Orientation: No rotation needed - IMU axes already mapped in software
    
    Physical IMU orientation:
    - IMU Y-axis points toward robot FRONT (cameras)
    - IMU X-axis points toward robot LEFT  
    - IMU Z-axis points UP
    
    This is handled by axis remapping in imu_node.py, so no RPY rotation needed here.
    -->
    <origin xyz="${imu_x_offset} ${imu_y_offset} ${imu_z_offset}" rpy="0 0 0"/>
  </joint>
  
  <!-- =====================================================
       CAMERAS (Microsoft LifeCam Studio) - VERIFIED
       Mounted at top of camera pole
       ===================================================== -->
  
  <!-- Camera mounting platform -->
  <link name="camera_mount">
    <visual>
      <geometry>
        <box size="0.15 0.10 0.03"/>
      </geometry>
      <material name="metal_gray"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.15 0.10 0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <joint name="pole_to_camera_mount" type="fixed">
    <parent link="camera_pole"/>
    <child link="camera_mount"/>
    <origin xyz="0 0 ${pole_height}" rpy="0 0 0"/>
  </joint>
  
  <!-- Main Camera Link -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.03 0.03"/>
      </geometry>
      <material name="black_rubber"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.03 0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="mount_to_camera_link" type="fixed">
    <parent link="camera_mount"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>
  
  <!-- Front-facing Camera -->
  <link name="camera_front_link">
    <visual>
      <geometry>
        <box size="0.05 0.03 0.03"/>
      </geometry>
      <material name="black_rubber"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.03 0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="mount_to_camera_front" type="fixed">
    <parent link="camera_mount"/>
    <child link="camera_front_link"/>
    <origin xyz="0.075 0 0.02" rpy="0 0 0"/>
  </joint>
  
  <!-- Back-facing Camera -->
  <link name="camera_back_link">
    <visual>
      <geometry>
        <box size="0.05 0.03 0.03"/>
      </geometry>
      <material name="black_rubber"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.03 0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="mount_to_camera_back" type="fixed">
    <parent link="camera_mount"/>
    <child link="camera_back_link"/>
    <origin xyz="-0.075 0 0.02" rpy="0 0 ${pi}"/>
  </joint>

</robot>
